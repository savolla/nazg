# ----- Vanilla Fish Config with Vi Mode -----

# Clear greeting
set fish_greeting

# Set terminal type
set -x TERM xterm-256color

# Enable vi key bindings
fish_vi_key_bindings


set -U fish_key_bindings fish_vi_key_bindings

# Optional: autosuggestions (if you have fish-autosuggestions installed)
if type -q fish_autosuggestion
    fish_autosuggestion
end

# Optional: basic prompt
function fish_prompt
    echo -n (pwd) ' > '
end
